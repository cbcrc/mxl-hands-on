# ============================================================
#  gst-apps — environment configuration template
#
#  Copy this file to .env and fill in the values below.
#
#    cp .env.template .env
#
#  .env is git-ignored so your local paths never end up in
#  the repository.
# ============================================================

# ------------------------------------------------------------
# MEDIA_DEVICE — required by the file-player service
# ------------------------------------------------------------
# Absolute path to a directory on the HOST that contains the
# media files (MP4 / TS) you want the File Player to loop.
#
# The directory is mounted read-only inside the container at
# /home/file  (see docker-compose.yml → file-player → volumes).
#
# Examples:
#   Linux / WSL:  MEDIA_DEVICE=/home/<your-user>/clips
#   macOS:        MEDIA_DEVICE=/Users/<your-user>/clips
#
MEDIA_DEVICE=/path/to/your/media/clips
